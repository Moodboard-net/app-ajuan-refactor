# PostgreSQL (Docker Compose)
POSTGRES_USER=ajuan
POSTGRES_PASSWORD=
POSTGRES_DB=ajuan_pembayaran

# RustFS (S3-compatible object storage, Docker Compose)
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=ajuan-pembayaran

# App
APP_SESSION_SECRET=
DATABASE_URL=postgres://ajuan:CHANGE_ME@localhost:5432/ajuan_pembayaran
RUSTFS_ENDPOINT=http://localhost:9000
# Endpoint yang dipakai browser untuk membuka signed URL (foto profil, bukti transfer, LPJ).
# Saat app juga jalan di Docker Compose, RUSTFS_ENDPOINT jadi "http://rustfs:9000" (hanya
# bisa di-resolve antar container) sehingga variabel ini WAJIB diisi terpisah, mis. "http://localhost:9000".
RUSTFS_PUBLIC_ENDPOINT=http://localhost:9000

# Seed akun awal (dipakai oleh `npm run db:seed`, jangan commit nilai asli)
SEED_SUPER_ADMIN_USERNAME=superadmin
SEED_SUPER_ADMIN_PASSWORD=
SEED_APPROVAL_USERNAME=approval
SEED_APPROVAL_PASSWORD=

# Migrasi data lama (hanya dipakai sekali oleh `npm run db:migrate-legacy`)
OLD_DATABASE_URL=
