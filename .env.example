# PostgreSQL (Docker Compose)
POSTGRES_USER=ajuan
POSTGRES_PASSWORD=
POSTGRES_DB=ajuan_pembayaran

# RustFS (S3-compatible object storage, Docker Compose)
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=ajuan-pembayaran

# App
APP_SESSION_SECRET=
DATABASE_URL=postgres://ajuan:CHANGE_ME@localhost:5432/ajuan_pembayaran
RUSTFS_ENDPOINT=http://localhost:9000

# Seed akun awal (dipakai oleh `npm run db:seed`, jangan commit nilai asli)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
SEED_DIRKEU_USERNAME=dirkeu
SEED_DIRKEU_PASSWORD=
SEED_DIVISI_PASSWORD=

# Migrasi data lama (hanya dipakai sekali oleh `npm run db:migrate-legacy`)
OLD_DATABASE_URL=
